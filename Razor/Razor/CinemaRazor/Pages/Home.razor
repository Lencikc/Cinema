@page "/"
@using CinemaRazor.Models
@using System.Text.Json
@using CinemaRazor.Services
@inject Api Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Cinema Hall</PageTitle>

<div id="cinemaCarousel" class="carousel slide mb-4 rounded overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#cinemaCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#cinemaCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#cinemaCarousel" data-bs-slide-to="2"></button>
    </div>
    <div class="carousel-inner" style="max-height:520px;">
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1485095329183-d0797cdc5676?auto=format&fit=crop&w=1600&q=80" class="d-block w-100" style="height:520px;object-fit:cover;" alt="" />
            <div class="carousel-caption text-start" style="left:5%;right:auto;bottom:30%;max-width:600px;">
                <h2 class="display-4 fw-bold">Премьеры мая</h2>
                <p class="lead">Лучшие фильмы недели уже в нашем кинотеатре</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?auto=format&fit=crop&w=1600&q=80" class="d-block w-100" style="height:520px;object-fit:cover;" alt="" />
            <div class="carousel-caption text-start" style="left:5%;right:auto;bottom:30%;max-width:600px;">
                <h2 class="display-4 fw-bold">Бронируй заранее</h2>
                <p class="lead">Лучшие места разбирают быстро</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&w=1600&q=80" class="d-block w-100" style="height:520px;object-fit:cover;" alt="" />
            <div class="carousel-caption text-start" style="left:5%;right:auto;bottom:30%;max-width:600px;">
                <h2 class="display-4 fw-bold">Попкорн и напитки</h2>
                <p class="lead">Заказывай в баре прямо к креслу</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#cinemaCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#cinemaCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="d-flex">
            <i class="bi bi-ticket-perforated fs-1 text-warning me-3"></i>
            <div>
                <h5 class="text-white">Электронные билеты</h5>
                <p class="text-white-50 small mb-0">Покупка онлайн, QR-код в личном кабинете</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex">
            <i class="bi bi-cup-hot fs-1 text-warning me-3"></i>
            <div>
                <h5 class="text-white">Бар к месту</h5>
                <p class="text-white-50 small mb-0">Закажи попкорн и напитки заранее</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex">
            <i class="bi bi-gift fs-1 text-warning me-3"></i>
            <div>
                <h5 class="text-white">Промокоды и акции</h5>
                <p class="text-white-50 small mb-0">Скидки на сеансы и подписку</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-3">
    <h2 class="text-white">В прокате сейчас</h2>
    <a href="/afisha" class="btn btn-outline-warning btn-sm">Вся афиша →</a>
</div>

@if (movies == null)
{
    <p class="text-white-50">Загрузка...</p>
}
else
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var m in movies.Take(8))
        {
            <div class="col">
                <div class="card bg-dark border-secondary h-100" @onclick="@(() => Nav.NavigateTo($"/movie/{m.MovieID}"))" style="cursor:pointer;">
                    <img src="@PosterFor(m)" class="card-img-top" style="aspect-ratio:2/3;object-fit:cover;" alt="@m.Title" />
                    <div class="card-body">
                        <h5 class="card-title text-white">@m.Title</h5>
                        <p class="card-text text-white-50 small mb-2">@m.GenreName · @m.DurationMinutes мин</p>
                        <span class="badge bg-danger">@m.AgeRatingLabel</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<MovieDto>? movies;

    protected override async Task OnInitializedAsync()
    {
        var r = await Api.Get("/cinema/movies");
        if (r != null && r.Value.TryGetProperty("movies", out var arr))
            movies = JsonSerializer.Deserialize<List<MovieDto>>(arr.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
    }

    private string PosterFor(MovieDto m) =>
        string.IsNullOrEmpty(m.PosterUrl) ? $"https://picsum.photos/seed/m{m.MovieID}/400/600" : m.PosterUrl;
}
