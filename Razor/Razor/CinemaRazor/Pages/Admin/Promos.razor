@page "/admin/promos"
@using CinemaRazor.Models
@using CinemaRazor.Requests
@using System.Text.Json
@using CinemaRazor.Services
@inject Api Api
@inject AuthState Auth

<PageTitle>Промокоды</PageTitle>

<div class="page-header">
    <div><h1 class="page-title">Промокоды</h1><p class="page-subtitle">Создание скидок и акций</p></div>
</div>

@if (!Auth.IsAdmin)
{
    <div class="alert alert-danger">Только админу</div>
}
else
{
    <div class="card-dark mb-3">
        <h5 class="section-title">Новый промокод</h5>
        <div class="row g-2">
            <div class="col-12 col-md-3"><label class="app-label">Код</label><input class="form-control" @bind="add.PromoCode" /></div>
            <div class="col-12 col-md-3"><label class="app-label">Название</label><input class="form-control" @bind="add.PromoName" /></div>
            <div class="col-6 col-md-1"><label class="app-label">%</label><input class="form-control" type="number" min="1" max="100" @bind="add.DiscountPercent" /></div>
            <div class="col-6 col-md-2"><label class="app-label">С</label><input class="form-control" type="date" min="@TodayStr" @bind="add.ValidFrom" /></div>
            <div class="col-6 col-md-2"><label class="app-label">По</label><input class="form-control" type="date" min="@(add.ValidFrom.ToString("yyyy-MM-dd"))" @bind="add.ValidTo" /></div>
            <div class="col-6 col-md-1 d-flex align-items-end"><button class="btn btn-warning w-100" @onclick="DoAdd">+</button></div>
        </div>
    </div>

    @if (promos != null)
    {
        <div class="card-dark p-0 overflow-hidden">
            <table class="table table-dark table-hover table-striped align-middle mb-0">
                <thead><tr class="text-warning text-uppercase small"><th class="ps-3">Код</th><th>Название</th><th>Скидка</th><th>Период</th><th>Активен</th><th></th></tr></thead>
                <tbody>
                    @foreach (var p in promos)
                    {
                        <tr>
                            <td><strong style="color:#fbbf24;">@p.PromoCode</strong></td>
                            <td>@p.PromoName</td>
                            <td>@p.DiscountPercent%</td>
                            <td>@p.ValidFrom.ToString("dd.MM.yy") — @p.ValidTo.ToString("dd.MM.yy")</td>
                            <td>@(p.IsActive ? "✓" : "—")</td>
                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DoDelete(p.PromoID)"><i class="bi bi-trash"></i></button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@inject CinemaRazor.Services.Toast Toast

@code {
    private List<PromoDto>? promos;
    private AddPromoModel add = new();
    private string TodayStr => DateTime.Today.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var r = await Api.Get("/cinema/admin/promos");
        if (r != null && r.Value.TryGetProperty("promos", out var arr))
            promos = JsonSerializer.Deserialize<List<PromoDto>>(arr.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
    }

    private async Task DoAdd()
    {
        if (string.IsNullOrWhiteSpace(add.PromoCode)) { Toast.Error("Введите код"); return; }
        if (string.IsNullOrWhiteSpace(add.PromoName)) { Toast.Error("Введите название"); return; }
        if (add.DiscountPercent <= 0 || add.DiscountPercent > 100) { Toast.Error("Скидка от 1 до 100%"); return; }
        if (add.ValidFrom.Date < DateTime.Today) { Toast.Error("Дата начала не раньше сегодня"); return; }
        if (add.ValidTo.Date < add.ValidFrom.Date) { Toast.Error("Дата окончания не раньше даты начала"); return; }

        var r = await Api.Post("/cinema/admin/promo", add);
        if (r == null) { Toast.Error("Сервер не отвечает"); return; }
        if (r.Value.GetProperty("status").GetBoolean())
        {
            Toast.Success("Промокод создан");
            add = new();
            await Load();
        }
        else Toast.Error(r.Value.TryGetProperty("message", out var m) ? m.GetString() ?? "Ошибка" : "Ошибка");
    }

    private async Task DoDelete(int id)
    {
        await Api.Delete($"/cinema/admin/promo/{id}");
        await Load();
    }
}
