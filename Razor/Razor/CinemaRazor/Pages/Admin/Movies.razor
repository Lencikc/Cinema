@page "/admin/movies"
@using CinemaRazor.Models
@using CinemaRazor.Requests
@using System.Text.Json
@using System.Net.Http.Headers
@using CinemaRazor.Services
@inject Api Api
@inject AuthState Auth
@inject Toast Toast
@inject HttpClient Http

<PageTitle>Фильмы (админ)</PageTitle>

<div class="page-header">
    <div><h1 class="page-title">Фильмы</h1><p class="page-subtitle">Управление каталогом фильмов</p></div>
</div>

@if (!Auth.IsAdmin)
{
    <div class="alert alert-danger">Доступ только администраторам</div>
}
else
{
    <div class="card-dark mb-3">
        <h5 class="section-title">Добавить фильм</h5>
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <label class="app-label">Название *</label>
                <input class="form-control" @bind="add.Title" />
            </div>
            <div class="col-6 col-md-3">
                <label class="app-label">Жанр *</label>
                <select class="form-select" @bind="add.GenreID">
                    <option value="0">— выбрать —</option>
                    @foreach (var g in genres) { <option value="@g.GenreID">@g.GenreName</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="app-label">Возраст *</label>
                <select class="form-select" @bind="add.AgeRatingID">
                    <option value="0">— выбрать —</option>
                    @foreach (var a in ages) { <option value="@a.AgeRatingID">@a.Label</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="app-label">Длит-сть, мин *</label>
                <input class="form-control" type="number" min="1" @bind="add.DurationMinutes" />
            </div>
            <div class="col-6 col-md-1">
                <label class="app-label">Год *</label>
                <input class="form-control" type="number" @bind="add.ReleaseYear" />
            </div>
            <div class="col-12">
                <label class="app-label">Описание *</label>
                <textarea class="form-control" rows="2" @bind="add.Description"></textarea>
            </div>
            <div class="col-12">
                <label class="app-label">Постер (файл)</label>
                <InputFile class="form-control" OnChange="OnPosterPicked" accept="image/*" />
                @if (uploading) { <small class="text-warning">Загрузка...</small> }
                @if (!string.IsNullOrEmpty(add.PosterUrl)) { <img src="@add.PosterUrl" style="max-height:80px; margin-top:8px;" /> }
            </div>
            <div class="col-12 d-flex justify-content-end">
                <button class="btn btn-warning" @onclick="DoAdd">Добавить</button>
            </div>
        </div>
    </div>

    @if (movies == null)
    {
        <div class="card-dark"><p class="page-subtitle text-center">Загрузка...</p></div>
    }
    else
    {
        <div class="card-dark p-0 overflow-hidden">
            <table class="table table-dark table-hover table-striped align-middle mb-0">
                <thead><tr class="text-warning text-uppercase small"><th class="ps-3">ID</th><th>Постер</th><th>Название</th><th>Жанр</th><th>Длит.</th><th>Возр.</th><th>Активен</th><th></th></tr></thead>
                <tbody>
                    @foreach (var m in movies)
                    {
                        <tr>
                            <td>@m.MovieID</td>
                            <td><img src="@(string.IsNullOrEmpty(m.PosterUrl) ? "" : m.PosterUrl)" style="width:40px;height:60px;object-fit:cover;border-radius:4px;" /></td>
                            <td>@m.Title</td>
                            <td>@m.GenreName</td>
                            <td>@m.DurationMinutes</td>
                            <td>@m.AgeRatingLabel</td>
                            <td>@(m.IsActive ? "✓" : "—")</td>
                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DoDelete(m.MovieID)"><i class="bi bi-trash"></i></button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<MovieDto>? movies;
    private List<GenreDto> genres = new();
    private List<AgeRatingDto> ages = new();
    private AddMovieModel add = new();
    private bool uploading;

    protected override async Task OnInitializedAsync()
    {
        await LoadRefs();
        await Load();
    }

    private async Task LoadRefs()
    {
        var rg = await Api.Get("/cinema/refs/genres");
        if (rg != null && rg.Value.TryGetProperty("genres", out var ag))
            genres = JsonSerializer.Deserialize<List<GenreDto>>(ag.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

        var ra = await Api.Get("/cinema/refs/ageratings");
        if (ra != null && ra.Value.TryGetProperty("ageRatings", out var aa))
            ages = JsonSerializer.Deserialize<List<AgeRatingDto>>(aa.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
    }

    private async Task Load()
    {
        var r = await Api.Get("/cinema/movies");
        if (r != null && r.Value.TryGetProperty("movies", out var arr))
            movies = JsonSerializer.Deserialize<List<MovieDto>>(arr.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
    }

    private async Task OnPosterPicked(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        uploading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var sc = new StreamContent(stream);
            sc.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(sc, "file", file.Name);

            if (!string.IsNullOrEmpty(Auth.Token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Auth.Token);

            var resp = await Http.PostAsync("/cinema/upload", content);
            var txt = await resp.Content.ReadAsStringAsync();
            var json = JsonDocument.Parse(txt).RootElement;
            if (json.GetProperty("status").GetBoolean())
            {
                add.PosterUrl = json.GetProperty("url").GetString();
                Toast.Success("Постер загружен");
            }
            else
            {
                Toast.Error(json.TryGetProperty("message", out var m) ? m.GetString() ?? "Ошибка" : "Ошибка");
            }
        }
        catch (Exception ex) { Toast.Error("Не удалось загрузить: " + ex.Message); }
        uploading = false;
    }

    private async Task DoAdd()
    {
        var r = await Api.Post("/cinema/admin/movie", add);
        if (r == null) { Toast.Error("Сервер не отвечает"); return; }
        if (r.Value.GetProperty("status").GetBoolean())
        {
            Toast.Success("Фильм добавлен");
            add = new();
            await Load();
        }
        else Toast.Error(r.Value.GetProperty("message").GetString() ?? "Ошибка");
    }

    private async Task DoDelete(int id)
    {
        var r = await Api.Delete($"/cinema/admin/movie/{id}");
        if (r != null && r.Value.GetProperty("status").GetBoolean())
        {
            Toast.Success("Удалено");
            await Load();
        }
        else Toast.Error("Ошибка удаления");
    }
}
