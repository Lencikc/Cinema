@page "/today-shows"
@using System.Text.Json
@using CinemaRazor.Services
@inject Api Api

<PageTitle>Сеансы сегодня</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Сеансы сегодня</h1>
        <p class="page-subtitle">Расписание и посещаемость</p>
    </div>
</div>

@if (data == null)
{
    <div class="card-dark"><p class="page-subtitle text-center">Загрузка...</p></div>
}
else
{
    <div class="card-dark p-0 overflow-hidden">
        <table class="table table-dark table-hover table-striped align-middle mb-0">
            <thead><tr class="text-warning text-uppercase small"><th class="ps-3">#</th><th>Время</th><th>Фильм</th><th>Зал</th><th>Статус</th></tr></thead>
            <tbody>
                @foreach (var s in data.Value.GetProperty("shows").EnumerateArray())
                {
                    <tr>
                        <td>@s.GetProperty("showID").GetInt32()</td>
                        <td>@s.GetProperty("startTime").GetDateTime().ToLocalTime().ToString("HH:mm")</td>
                        <td>@s.GetProperty("movieTitle").GetString()</td>
                        <td>@s.GetProperty("hallName").GetString()</td>
                        <td><span class="hero-chip">@s.GetProperty("status").GetString()</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private JsonElement? data;

    protected override async Task OnInitializedAsync()
    {
        data = await Api.Get("/cinema/today");
    }
}
