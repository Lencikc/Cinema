@page "/account"
@page "/login"
@page "/register"
@using CinemaRazor.Models
@using CinemaRazor.Requests
@using System.Text.Json
@using CinemaRazor.Services
@inject Api Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Личный кабинет</PageTitle>

@if (Auth.IsLogged)
{
    <div class="row justify-content-center">
        <div class="col-12 col-md-8">
            <div class="card bg-dark border-secondary">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Личный кабинет</h4>
                </div>
                <div class="card-body">
                    <h3 class="text-white">@Auth.Current!.LastName @Auth.Current.FirstName</h3>
                    <p><span class="badge bg-warning text-dark">@Auth.Current.RoleName</span></p>
                    <hr class="border-secondary" />
                    <dl class="row text-white">
                        <dt class="col-sm-3 text-white-50">Email:</dt>
                        <dd class="col-sm-9">@Auth.Current.Email</dd>
                        <dt class="col-sm-3 text-white-50">Телефон:</dt>
                        <dd class="col-sm-9">@(string.IsNullOrEmpty(Auth.Current.Phone) ? "—" : Auth.Current.Phone)</dd>
                    </dl>
                    <button class="btn btn-outline-danger" @onclick="DoLogout">
                        <i class="bi bi-box-arrow-right me-2"></i>Выйти
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
            <div class="card bg-dark border-secondary">
                <div class="card-header bg-transparent border-secondary p-0">
                    <ul class="nav nav-pills nav-fill p-2 gap-2" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(mode == "in" ? "bg-warning text-dark fw-bold" : "text-warning")"
                                    @onclick="@(() => mode = "in")">Вход</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(mode == "up" ? "bg-warning text-dark fw-bold" : "text-warning")"
                                    @onclick="@(() => mode = "up")">Регистрация</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    @if (mode == "in")
                    {
                        <div class="mb-3">
                            <label class="form-label text-white">Email</label>
                            <input class="form-control" @bind="signIn.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white">Пароль</label>
                            <input class="form-control" type="password" @bind="signIn.Password" />
                        </div>
                        @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger">@error</div> }
                        <button class="btn btn-warning w-100" @onclick="DoSignIn">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Войти
                        </button>
                    }
                    else
                    {
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label text-white">Фамилия</label>
                                <input class="form-control" @bind="signUp.LastName" />
                            </div>
                            <div class="col-6">
                                <label class="form-label text-white">Имя</label>
                                <input class="form-control" @bind="signUp.FirstName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-white">Отчество</label>
                                <input class="form-control" @bind="signUp.Patronymic" />
                            </div>
                            <div class="col-7">
                                <label class="form-label text-white">Телефон</label>
                                <input class="form-control" @bind="signUp.Phone" />
                            </div>
                            <div class="col-5">
                                <label class="form-label text-white">Дата рождения</label>
                                <input class="form-control" type="date" @bind="signUpBirth" />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-white">Email</label>
                                <input class="form-control" @bind="signUp.Email" />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-white">Пароль</label>
                                <input class="form-control" type="password" @bind="signUp.Password" />
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger mt-3">@error</div> }
                        @if (!string.IsNullOrEmpty(ok)) { <div class="alert alert-success mt-3">@ok</div> }
                        <button class="btn btn-warning w-100 mt-3" @onclick="DoSignUp">
                            <i class="bi bi-person-plus me-2"></i>Зарегистрироваться
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string mode = "in";
    private SignInModel signIn = new();
    private SignUpModel signUp = new();
    private DateTime? signUpBirth;
    private string? error;
    private string? ok;

    protected override void OnInitialized()
    {
        if (Nav.Uri.EndsWith("/register")) mode = "up";
    }

    private async Task DoSignIn()
    {
        error = null;
        var r = await Api.Post("/cinema/signin", signIn);
        if (r == null) { error = "Сервер не отвечает"; return; }
        var json = r.Value;
        if (!json.TryGetProperty("status", out var st) || !st.GetBoolean())
        {
            error = json.TryGetProperty("message", out var m) ? m.GetString() : "Ошибка";
            return;
        }
        var token = json.GetProperty("token").GetString() ?? "";
        var u = json.GetProperty("logedUser");
        var user = new UserDto
        {
            UserID = u.GetProperty("userID").GetInt32(),
            LastName = u.GetProperty("lastName").GetString() ?? "",
            FirstName = u.GetProperty("firstName").GetString() ?? "",
            Patronymic = u.TryGetProperty("patronymic", out var p) ? p.GetString() : null,
            Phone = u.TryGetProperty("phone", out var ph) ? ph.GetString() : null,
            RoleID = u.GetProperty("roleID").GetInt32(),
            RoleName = u.GetProperty("roleName").GetString() ?? "",
            Email = u.GetProperty("email").GetString() ?? ""
        };
        Auth.Set(user, token);
        Nav.NavigateTo("/");
    }

    private async Task DoSignUp()
    {
        error = null; ok = null;
        if (string.IsNullOrWhiteSpace(signUp.LastName) || string.IsNullOrWhiteSpace(signUp.FirstName) ||
            string.IsNullOrWhiteSpace(signUp.Email) || string.IsNullOrWhiteSpace(signUp.Password))
        { error = "Заполните обязательные поля"; return; }

        if (signUpBirth.HasValue)
            signUp.BirthDate = DateOnly.FromDateTime(signUpBirth.Value);

        var r = await Api.Post("/cinema/signup", signUp);
        if (r == null) { error = "Нет ответа"; return; }
        if (r.Value.TryGetProperty("status", out var st) && st.GetBoolean())
        {
            ok = "Аккаунт создан, войдите";
            mode = "in";
            signIn.Email = signUp.Email;
            signUp = new();
            signUpBirth = null;
        }
        else
        {
            error = r.Value.TryGetProperty("message", out var m) ? m.GetString() : "Ошибка";
        }
    }

    private void DoLogout() { Auth.Clear(); Nav.NavigateTo("/"); }
}
